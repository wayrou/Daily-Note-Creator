{
  "name": "koala",
  "version": "1.0.4",
  "description": "Koala desktop app for generating classroom and therapy daily notes.",
  "main": "electron/main.cjs",
  "type": "module",
  "author": "Alex Hungate",
  "license": "UNLICENSED",
  "scripts": {
    "start": "node server.js",
    "desktop": "electron .",
    "dist": "electron-builder --publish never",
    "dist:mac": "electron-builder --mac dmg zip --publish never",
    "dist:win": "electron-builder --win nsis portable --publish never"
  },
  "build": {
    "appId": "com.alexhungate.koala",
    "productName": "Koala",
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "index.html",
      "app.js",
      "styles.css",
      "logo-image.js",
      "template-image.js",
      "assets/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  }
}
