{
  "name": "koala",
  "version": "1.0.10",
  "description": "Koala desktop app for generating classroom and therapy daily notes.",
  "main": "electron/main.cjs",
  "type": "module",
  "author": "Alex Hungate",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/wayrou/Daily-Note-Creator.git"
  },
  "scripts": {
    "start": "node server.js",
    "desktop": "electron .",
    "dist": "electron-builder --publish never",
    "dist:mac": "electron-builder --mac dmg zip --publish never",
    "dist:win": "electron-builder --win nsis portable --publish never"
  },
  "build": {
    "appId": "com.alexhungate.koala",
    "productName": "Koala",
    "afterPack": "electron/after-pack.cjs",
    "afterSign": "electron/notarize.cjs",
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "index.html",
      "app.js",
      "styles.css",
      "logo-image.js",
      "template-image.js",
      "assets/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "wayrou",
        "repo": "Daily-Note-Creator",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  }
}
